# OpenSearch (local development)
OPENSEARCH_MODE=fake
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_INDEX_NAME=public-law-ai-local
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# law.go.kr (National Law Information Center)
LAW_GO_KR_BASE_URL=https://www.law.go.kr
LAW_GO_KR_OC=

# PostgreSQL (local development)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# --------------------------------------------------------------------------
# Application Configuration (app/legal/config — production runtime)
# See docs/configuration.md for full details, defaults, and validation rules.
# --------------------------------------------------------------------------

# Environment / logging
APP_ENVIRONMENT=development
LOG_LEVEL=info

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database
# Shares POSTGRES_HOST / POSTGRES_PORT / POSTGRES_DATABASE / POSTGRES_PASSWORD
# above with the legacy pipeline config. POSTGRES_USERNAME is read separately
# by the ApplicationConfiguration factory.
POSTGRES_USERNAME=public_law_ai

# Search
# ApplicationConfiguration reads OPENSEARCH_NODE_URL (distinct from the
# legacy pipeline's OPENSEARCH_NODE above). Shares OPENSEARCH_INDEX_NAME above.
OPENSEARCH_NODE_URL=http://localhost:9200

# AI Provider
# LLM_PROVIDER: fake | openai | anthropic
# Use "fake" for local development — no real API key required.
LLM_PROVIDER=fake
LLM_MODEL=fake-model
# Required only when LLM_PROVIDER is openai or anthropic. Never commit a real key.
LLM_API_KEY=
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
